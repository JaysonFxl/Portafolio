---
interface ContactLink {
  platform: string;
  url: string;
  icon?: string;
}

interface Props {
  title?: string;
  email?: string;
  location?: string;
  socialLinks?: ContactLink[];
}

const { 
  title = "Contacto",
  email = "fseba196@gmail.com",
  location = "Mulchen, Chile",
  socialLinks = [
    {
      platform: "LinkedIn",
      url: "https://linkedin.com/in/jayson-flores-cartes-7b2536249/",
      icon: "linkedin"
    },
    {
      platform: "GitHub",
      url: "https://github.com/JaysonFxl",
      icon: "github"
    },
    {
      platform: "Gmail",
      url: "https://mail.google.com/mail/?view=cm&to=fseba196@gmail.com",
      icon: "email"
    }
  ]
} = Astro.props;

const socialIcons: Record<string, string> = {
  linkedin: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  github: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  twitter: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>`,
  email: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`
};
---

<section id="contacto" class="relative py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#050510] via-[#070718] to-[#050510] z-0">
    <div class="absolute inset-0 opacity-[0.04] bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.12)_0.5px,transparent_0.5px)] bg-[size:24px_24px]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-blue-600/[0.03] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 bg-purple-600/[0.03] rounded-full blur-[120px]"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section heading -->
    <div class="text-center mb-16 animate-on-scroll">
      <div class="inline-block mb-4">
        <span class="px-4 py-1.5 bg-white/[0.03] text-blue-400 rounded-full text-xs font-semibold tracking-widest uppercase border border-white/[0.06] backdrop-blur-sm">
          Conectemos
        </span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4 tracking-tight">{title}</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-purple-600 mx-auto rounded-full"></div>
      <p class="mt-5 max-w-2xl mx-auto text-white/50 text-base leading-relaxed">Estoy disponible para nuevos proyectos y colaboraciones. ¡Hablemos sobre tu próxima idea!</p>
    </div>
    
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children">
      <!-- Info card -->
      <div class="glass rounded-2xl p-8 glass-hover">
        <h3 class="text-2xl font-bold mb-4 text-white">Hablemos</h3>
        <p class="mb-8 text-white/50 leading-relaxed text-sm">
          ¿Tienes un proyecto en mente o simplemente quieres decir hola? No dudes en contactarme para discutir cómo puedo ayudarte a materializar tus ideas.
        </p>
        
        <div class="space-y-5">
          <a href={`mailto:${email}`} class="flex items-center group p-3 -mx-3 rounded-xl hover:bg-white/[0.03] transition-all duration-300">
            <div class="w-11 h-11 rounded-xl bg-blue-500/10 flex items-center justify-center mr-4 border border-blue-500/10 group-hover:border-blue-500/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <div class="text-xs text-white/40 font-medium mb-0.5">Email</div>
              <span class="text-blue-300 text-sm font-medium group-hover:text-blue-200 transition-colors">{email}</span>
            </div>
          </a>
          
          <div class="flex items-center p-3 -mx-3 rounded-xl">
            <div class="w-11 h-11 rounded-xl bg-purple-500/10 flex items-center justify-center mr-4 border border-purple-500/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <div class="text-xs text-white/40 font-medium mb-0.5">Ubicación</div>
              <span class="text-white/60 text-sm font-medium">{location}</span>
            </div>
          </div>
        </div>
        
        <!-- Social links -->
        <div class="mt-10">
          <h4 class="text-sm font-semibold mb-4 text-white/70 tracking-wide">Redes sociales</h4>
          <div class="flex gap-3">
            {socialLinks.map((link) => (
              <a 
                href={link.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="w-11 h-11 rounded-xl bg-white/[0.03] flex items-center justify-center hover:bg-white/[0.08] transition-all duration-300 border border-white/[0.06] hover:border-white/[0.12] text-white/50 hover:text-white hover:scale-110"
                title={link.platform}
              >
                <div set:html={socialIcons[link.icon || ''] || `<span class="text-sm font-bold">${link.platform[0]}</span>`} />
              </a>
            ))}
          </div>
        </div>
      </div>
      
      <!-- Form card -->
      <div class="glass rounded-2xl p-8 glass-hover">
        <h3 class="text-2xl font-bold mb-6 text-white">Envíame un mensaje</h3>
        <form class="space-y-5">
          <div>
            <label class="block mb-2 text-white/50 text-sm font-medium" for="contact-name">Nombre</label>
            <input 
              type="text" 
              id="contact-name" 
              class="w-full px-4 py-3 rounded-xl bg-white/[0.03] placeholder-white/20 text-white border border-white/[0.06] focus:outline-none focus:border-blue-500/40 focus:bg-white/[0.05] transition-all duration-300 text-sm"
              placeholder="Tu nombre"
            />
          </div>
          
          <div>
            <label class="block mb-2 text-white/50 text-sm font-medium" for="contact-email">Email</label>
            <input 
              type="email" 
              id="contact-email" 
              class="w-full px-4 py-3 rounded-xl bg-white/[0.03] placeholder-white/20 text-white border border-white/[0.06] focus:outline-none focus:border-blue-500/40 focus:bg-white/[0.05] transition-all duration-300 text-sm"
              placeholder="email@email.com"
            />
          </div>
          
          <div>
            <label class="block mb-2 text-white/50 text-sm font-medium" for="contact-message">Mensaje</label>
            <textarea 
              id="contact-message" 
              rows="4" 
              class="w-full px-4 py-3 rounded-xl bg-white/[0.03] placeholder-white/20 text-white border border-white/[0.06] focus:outline-none focus:border-blue-500/40 focus:bg-white/[0.05] transition-all duration-300 resize-none text-sm"
              placeholder="¿Cómo puedo ayudarte?"
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="group relative w-full px-6 py-3.5 overflow-hidden font-semibold rounded-xl text-white text-sm tracking-wide"
          >
            <span class="absolute inset-0 bg-gradient-to-r from-blue-600 to-purple-600 group-hover:from-purple-600 group-hover:to-blue-600 transition-all duration-500"></span>
            <span class="relative flex items-center justify-center">
              Enviar Mensaje
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>