---
interface Props {
  name?: string;
  title?: string;
}

const { 
  name = "Jayson Flores", 
  title = "Desarrollador FullStack"
} = Astro.props;
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Dark background with subtle gradient -->
  <div class="absolute inset-0 bg-[#050510] z-0">
    <!-- Ambient glow orbs -->
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-blue-600/[0.07] rounded-full blur-[120px] animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-purple-600/[0.07] rounded-full blur-[120px] animate-pulse-glow" style="animation-delay: 1.5s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-500/[0.03] rounded-full blur-[150px]"></div>
    
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.04] bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(to_right,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
    
    <!-- Diagonal lines -->
    <div class="absolute inset-0 opacity-[0.02] bg-[repeating-linear-gradient(45deg,transparent,transparent_40px,rgba(139,92,246,0.15)_40px,rgba(139,92,246,0.15)_41px)]"></div>
  </div>
  
  <div class="container mx-auto px-6 flex flex-col md:flex-row items-center relative z-10 py-24">
    <div class="md:w-3/5 flex flex-col items-start justify-center md:pr-14">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 mb-6 px-4 py-1.5 rounded-full border border-white/[0.08] bg-white/[0.03] text-sm backdrop-blur-sm animate-on-scroll">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-white/60 font-medium">Disponible para proyectos</span>
      </div>
      
      <!-- Name -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold mb-5 leading-[1.1] tracking-tight animate-on-scroll">
        <span class="text-white">Hola, soy</span><br/>
        <span class="text-gradient bg-[length:200%_auto] animate-gradient-shift">{name}</span>
      </h1>
      
      <!-- Title -->
      <div class="flex items-center gap-3 mb-6 animate-on-scroll">
        <div class="h-px w-8 bg-gradient-to-r from-blue-500 to-transparent"></div>
        <h2 class="text-xl sm:text-2xl text-white/70 font-light tracking-wide">{title}</h2>
      </div>
      
      <!-- Description -->
      <p class="text-lg mb-10 text-white/50 max-w-xl leading-relaxed animate-on-scroll">
        Desarrollo soluciones web creativas y funcionales, con un enfoque en la experiencia del usuario y código limpio.
      </p>
      
      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 animate-on-scroll">
        <a href="#proyectos" class="group relative px-7 py-3.5 rounded-xl overflow-hidden font-medium text-sm">
          <span class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-600 transition-all duration-500 group-hover:scale-105"></span>
          <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-r from-purple-600 to-blue-500"></span>
          <span class="absolute inset-[1px] rounded-[11px] bg-gradient-to-r from-blue-500 to-purple-600 opacity-0 group-hover:opacity-0"></span>
          <span class="relative flex items-center justify-center text-white font-semibold tracking-wide">
            Ver Proyectos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
        </a>
        
        <a href="#contacto" class="group px-7 py-3.5 rounded-xl border border-white/[0.1] hover:border-white/[0.2] hover:bg-white/[0.04] transition-all duration-300 text-white/70 hover:text-white flex items-center justify-center text-sm font-semibold tracking-wide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 opacity-60" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
          </svg>
          Contacto
        </a>
      </div>
      
      <!-- Scroll indicator -->
      <a href="#sobre-mi" class="hidden md:flex items-center mt-20 text-white/30 hover:text-white/60 transition-colors duration-300 cursor-pointer group">
        <div class="flex flex-col items-center gap-2">
          <span class="text-xs font-medium tracking-widest uppercase">Scroll</span>
          <div class="w-5 h-8 rounded-full border border-white/20 flex justify-center pt-1.5 group-hover:border-white/40 transition-colors">
            <div class="w-1 h-2 bg-white/40 rounded-full animate-bounce"></div>
          </div>
        </div>
      </a>
    </div>
    
    <div class="md:w-2/5 mt-14 md:mt-0 flex justify-center">
      <div class="relative">
        <!-- Orbital rings -->
        <div class="absolute -inset-6 border border-dashed border-white/[0.06] rounded-full animate-spin-slow"></div>
        <div class="absolute -inset-12 border border-white/[0.03] rounded-full animate-spin-slow" style="animation-direction: reverse; animation-duration: 35s;"></div>
        
        <!-- Main avatar circle -->
        <div class="w-56 h-56 sm:w-64 sm:h-64 bg-gradient-to-br from-blue-600/80 to-purple-600/80 rounded-full flex items-center justify-center shadow-2xl shadow-purple-500/10 z-10 relative overflow-hidden border border-white/10">
          <div class="text-8xl">👨‍💻</div>
          <!-- Shine effect -->
          <div class="absolute -top-12 -right-12 w-24 h-24 bg-white/10 blur-2xl rounded-full"></div>
          <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-black/20 to-transparent"></div>
        </div>
        
        <!-- Floating dots -->
        <div class="absolute -top-3 -right-3 w-4 h-4 bg-blue-400 rounded-full blur-[1px] animate-float opacity-60"></div>
        <div class="absolute -bottom-3 -left-3 w-3 h-3 bg-purple-400 rounded-full blur-[1px] animate-float-delayed opacity-60"></div>
        <div class="absolute top-1/2 -right-8 w-2 h-2 bg-violet-400 rounded-full animate-float-slow opacity-40"></div>
      </div>
    </div>
  </div>
  
  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#050510] to-transparent z-20"></div>
</section>