---
interface Props {
  title?: string;
  subtitle?: string;
  cvUrl?: string;
}

const {
  title = "Curriculum Vitae",
  subtitle = "Descarga mi CV para revisar mi experiencia, stack y proyectos destacados.",
  cvUrl = "/cv/Jayson-Flores-CV.pdf"
} = Astro.props;
---

<section id="cv" class="relative py-28 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-[#050510] via-[#070718] to-[#050510] z-0">
    <div class="absolute inset-0 opacity-[0.04] bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(to_right,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:72px_72px]"></div>
    <div class="absolute top-24 right-8 w-72 h-72 bg-blue-600/[0.04] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-14 left-8 w-72 h-72 bg-purple-600/[0.04] rounded-full blur-[120px]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-14 animate-on-scroll">
      <div class="inline-block mb-4">
        <span class="px-4 py-1.5 bg-white/[0.03] text-blue-400 rounded-full text-xs font-semibold tracking-widest uppercase border border-white/[0.06] backdrop-blur-sm">
          Perfil Profesional
        </span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4 tracking-tight">{title}</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-purple-600 mx-auto rounded-full"></div>
      <p class="mt-5 max-w-2xl mx-auto text-white/50 text-base leading-relaxed">{subtitle}</p>
    </div>

    <div class="max-w-4xl mx-auto glass rounded-3xl p-7 sm:p-10 animate-on-scroll">
      <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold text-white mb-3">CV actualizado y listo para descarga</h3>
          <p class="text-white/55 leading-relaxed text-sm sm:text-base">
            Incluye experiencia, tecnologías, formación y enlaces clave. Si estás evaluando una colaboración o proceso de selección,
            aquí tienes una versión directa y fácil de compartir.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row md:flex-col gap-3 md:items-stretch">
          <a
            href={cvUrl}
            download
            class="group relative px-6 py-3.5 rounded-xl overflow-hidden font-semibold text-sm tracking-wide text-center"
          >
            <span class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-600 transition-all duration-500 group-hover:scale-105"></span>
            <span class="relative text-white inline-flex items-center justify-center gap-2">
              Descargar CV
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 14a1 1 0 011 1v1h12v-1a1 1 0 112 0v2a1 1 0 01-1 1H3a1 1 0 01-1-1v-2a1 1 0 011-1z" clip-rule="evenodd" />
                <path fill-rule="evenodd" d="M9 3a1 1 0 012 0v7.586l2.293-2.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 10.586V3z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>

          <a
            href={cvUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3.5 rounded-xl border border-white/[0.12] hover:border-white/[0.2] hover:bg-white/[0.04] transition-all duration-300 text-white/75 hover:text-white text-sm font-semibold tracking-wide text-center"
          >
            Ver en navegador
          </a>
        </div>
      </div>
    </div>
  </div>
</section>