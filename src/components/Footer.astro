---
interface Props {
  name?: string;
  year?: number;
}

const { 
  name = "Jayson Flores",
  year = new Date().getFullYear()
} = Astro.props;
---

<footer class="relative py-12 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-[#030308] z-0">
    <div class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(to_right,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:32px_32px]"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Top divider -->
    <div class="h-px w-full bg-gradient-to-r from-transparent via-white/[0.06] to-transparent mb-10"></div>
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
      <div>
        <a href="/" class="flex items-center gap-2.5 group mb-3" onclick="window.location.reload(); return false;">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-xs font-bold">
            JF
          </div>
          <span class="text-xl font-bold text-gradient">Jayson Flores</span>
        </a>
        <p class="text-white/30 text-sm max-w-sm leading-relaxed">
          Desarrollando soluciones digitales con pasión y creatividad.
        </p>
      </div>
      
      <div>
        <h4 class="text-white/60 font-semibold text-sm mb-3">Navegación</h4>
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2">
          <li><a href="#inicio" class="text-white/30 hover:text-white/70 transition-colors text-sm flex items-center gap-2">
            <span class="w-1 h-1 bg-white/20 rounded-full"></span>Inicio
          </a></li>
          <li><a href="#sobre-mi" class="text-white/30 hover:text-white/70 transition-colors text-sm flex items-center gap-2">
            <span class="w-1 h-1 bg-white/20 rounded-full"></span>Sobre Mí
          </a></li>
          <li><a href="#proyectos" class="text-white/30 hover:text-white/70 transition-colors text-sm flex items-center gap-2">
            <span class="w-1 h-1 bg-white/20 rounded-full"></span>Proyectos
          </a></li>
          <li><a href="#habilidades" class="text-white/30 hover:text-white/70 transition-colors text-sm flex items-center gap-2">
            <span class="w-1 h-1 bg-white/20 rounded-full"></span>Habilidades
          </a></li>
          <li><a href="#contacto" class="text-white/30 hover:text-white/70 transition-colors text-sm flex items-center gap-2">
            <span class="w-1 h-1 bg-white/20 rounded-full"></span>Contacto
          </a></li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom divider -->
    <div class="h-px w-full bg-gradient-to-r from-transparent via-white/[0.06] to-transparent my-8"></div>
    
    <div class="text-center md:flex md:justify-between md:items-center text-white/25 text-xs">
      <p>&copy; {year} <span class="text-white/40">{name}</span>. Todos los derechos reservados.</p>
    </div>
    
    <!-- Bottom bar -->
    <div class="flex justify-center mt-6">
      <div class="h-0.5 w-16 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full opacity-50"></div>
    </div>
  </div>
</footer>