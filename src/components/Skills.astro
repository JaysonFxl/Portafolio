---

<section id="habilidades" class="relative py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#050510] via-[#070718] to-[#050510] z-0">
    <div class="absolute inset-0 opacity-[0.03] bg-[repeating-linear-gradient(45deg,rgba(139,92,246,0.08),rgba(139,92,246,0.08)_1px,transparent_1px,transparent_8px)] bg-[size:16px_16px]"></div>
    <!-- Ambient orbs -->
    <div class="absolute top-1/3 right-0 w-[400px] h-[400px] bg-blue-600/[0.04] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/3 left-0 w-[400px] h-[400px] bg-purple-600/[0.04] rounded-full blur-[120px]"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section heading -->
    <div class="text-center mb-16 animate-on-scroll">
      <div class="inline-block mb-4">
        <span class="px-4 py-1.5 bg-white/[0.03] text-blue-400 rounded-full text-xs font-semibold tracking-widest uppercase border border-white/[0.06] backdrop-blur-sm">
          Tecnologías
        </span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4 tracking-tight">{title}</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-purple-600 mx-auto rounded-full"></div>
      <p class="mt-5 max-w-2xl mx-auto text-white/50 text-base leading-relaxed">Tecnologías y herramientas que domino para crear soluciones digitales eficientes y escalables.</p>
    </div>
    
    <!-- Skills grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {categories.map((category, index) => {
        const colors = categoryColors[category.title] || categoryColors["Frontend"];
        const catIcon = categoryIcons[category.title] || categoryIcons["Frontend"];
        return (
          <div class={`glass rounded-2xl p-7 glass-hover group`}>
            <!-- Category header -->
            <div class="flex items-center gap-3 mb-7 pb-4 border-b border-white/[0.06]">
              <div class={`w-10 h-10 rounded-xl ${colors.iconBg} flex items-center justify-center ${colors.text}`} set:html={catIcon} />
              <div>
                <span class={`text-xs font-bold tracking-widest uppercase ${colors.text}`}>0{index + 1}</span>
                <h3 class="text-xl font-bold text-white">{category.title}</h3>
              </div>
            </div>
            
            <!-- Skills list -->
            <div class="space-y-4">
              {category.skills.map((skill) => (
                <div class="group/skill flex items-center gap-3 p-2.5 -mx-2.5 rounded-xl hover:bg-white/[0.03] transition-all duration-300">
                  <!-- Skill icon -->
                  <div class={`w-9 h-9 rounded-lg ${colors.iconBg} flex items-center justify-center flex-shrink-0 ${colors.text} transition-all duration-300 group-hover/skill:scale-110`}>
                    <div class="w-4 h-4" set:html={skillIcons[skill.name] || `<span class="text-xs font-bold">${skill.name.charAt(0)}</span>`} />
                  </div>
                  
                  <!-- Skill details -->
                  <div class="flex-1 min-w-0">
                    <div class="flex justify-between items-center mb-1.5">
                      <span class="font-medium text-white/90 text-sm">{skill.name}</span>
                      <span class={`text-xs font-semibold ${colors.text} opacity-70`}>{skill.level}%</span>
                    </div>
                    
                    <!-- Progress bar -->
                    <div class="h-1.5 bg-white/[0.04] rounded-full overflow-hidden relative">
                      <div 
                        class={`h-full bg-gradient-to-r ${colors.gradient} rounded-full relative transition-all duration-700`}
                        style={`width: ${skill.level}%`}>
                        <div class="absolute right-0 top-0 h-full w-1.5 bg-white/40 rounded-full"></div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
    
    <!-- Stats section -->
    <div class="mt-16 glass rounded-2xl p-8 max-w-4xl mx-auto animate-on-scroll">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="p-4 group">
          <div class="text-4xl font-extrabold text-gradient mb-2">0</div>
          <div class="text-white/50 text-sm font-medium">Años de<br/>Experiencia</div>
        </div>
        <div class="p-4 group">
          <div class="text-4xl font-extrabold text-gradient mb-2">10</div>
          <div class="text-white/50 text-sm font-medium">Proyectos<br/>Completados</div>
        </div>
        <div class="p-4 group">
          <div class="text-4xl font-extrabold text-gradient mb-2">0</div>
          <div class="text-white/50 text-sm font-medium">Clientes<br/>Satisfechos</div>
        </div>
        <div class="p-4 group">
          <div class="text-4xl font-extrabold text-gradient mb-2">24/7</div>
          <div class="text-white/50 text-sm font-medium">Soporte<br/>Disponible</div>
        </div>
      </div>
    </div>
  </div>
</section>