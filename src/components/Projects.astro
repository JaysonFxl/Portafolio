---
interface Project {
  title: string;
  description: string;
  image: string;
  tags: string[];
  link?: string;
  github?: string;
}

interface Props {
  title?: string;
  projects?: Project[];
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;

const { 
  title = "Mis Proyectos",
  projects = [
    {
      title: "Proyecto El Futbolito",
      description: "El Futbolito es una aplicación web para la gestión de reservas de canchas de fútbol.",
      image: `${baseUrl}/projects/futbolito/image-1.png`,
      tags: ["React","JavaScript","HTML5","CSS", "Django", "PostgreSQL"],
      link: `${baseUrl}/gallery/futbolito`,
      github: "https://github.com/JaysonFxl/ProyectoRBP"
    },
    {
      title: "AhorroAPP",
      description: "AhorroAPP es una aplicación web para la gestión de ahorros. Permite tener un historial con graficos de ahorro a nivel personal.",
      image: `${baseUrl}/projects/ahorroapp/image-1.png`,
      tags: ["React", "HTML5","CSS","Django","PostgreSQL"],
      link: `${baseUrl}/gallery/ahorroapp`,
      github: "https://github.com/JaysonFxl/AhorroAPP"
    },
    {
      title: "EcoEventMobile",
      description: "EcoEventMobile es una aplicación móvil React Native para la gestión y organización de eventos ecológicos y sostenibles. Permite a los usuarios descubrir, crear y participar en eventos que promuevan la conciencia ambiental.",
      image: `${baseUrl}/projects/ecoevent-mobile/image-1.jpg`,
      tags: ["React Native", "TypeScript", "Tailwind","AWS"],
      link: `${baseUrl}/gallery/ecoevent-mobile`,
      github: "https://github.com/JaysonFxl/EventMobile"
    }
  ]
} = Astro.props;

// Tag colors
const tagColors: Record<string, string> = {
  "React": "text-cyan-300 bg-cyan-500/10 border-cyan-500/20",
  "React Native": "text-cyan-300 bg-cyan-500/10 border-cyan-500/20",
  "JavaScript": "text-yellow-300 bg-yellow-500/10 border-yellow-500/20",
  "TypeScript": "text-blue-300 bg-blue-500/10 border-blue-500/20",
  "HTML5": "text-orange-300 bg-orange-500/10 border-orange-500/20",
  "CSS": "text-blue-300 bg-blue-500/10 border-blue-500/20",
  "Django": "text-emerald-300 bg-emerald-500/10 border-emerald-500/20",
  "PostgreSQL": "text-sky-300 bg-sky-500/10 border-sky-500/20",
  "Tailwind": "text-teal-300 bg-teal-500/10 border-teal-500/20",
  "AWS": "text-amber-300 bg-amber-500/10 border-amber-500/20",
};

const defaultTagColor = "text-blue-300 bg-blue-500/10 border-blue-500/20";
---

<section id="proyectos" class="relative py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#050510] via-[#070718] to-[#050510] z-0">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,transparent_calc(100%_-_1px),rgba(255,255,255,0.02)_calc(100%_-_1px))] bg-[size:5vw_5vw]"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section heading -->
    <div class="text-center mb-16 animate-on-scroll">
      <div class="inline-block mb-4">
        <span class="px-4 py-1.5 bg-white/[0.03] text-blue-400 rounded-full text-xs font-semibold tracking-widest uppercase border border-white/[0.06] backdrop-blur-sm">
          Portafolio
        </span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4 tracking-tight">{title}</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-purple-600 mx-auto rounded-full"></div>
      <p class="mt-5 max-w-2xl mx-auto text-white/50 text-base leading-relaxed">Explora mis proyectos más recientes y descubre cómo puedo ayudarte a construir soluciones digitales innovadoras.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {projects.map((project) => (
        <div class="group glass rounded-2xl overflow-hidden glass-hover hover:-translate-y-1 transition-all duration-500">
          <!-- Image -->
          <div class="h-52 overflow-hidden relative">
            <!-- Overlay gradient on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#050510] via-[#050510]/50 to-transparent opacity-30 group-hover:opacity-60 transition-opacity duration-500 z-10"></div>
            
            {project.image ? (
              <img 
                src={project.image} 
                alt={`Vista previa: ${project.title}`} 
                class={`w-full h-full opacity-80 group-hover:opacity-100 transition-all duration-700 group-hover:scale-110 ${
                  project.title === "EcoEventMobile" 
                    ? "object-contain bg-[#050510]" 
                    : "object-cover"
                }`}
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-900/20 to-purple-900/20 text-white/30">
                <div class="text-center">
                  <div class="text-4xl mb-2">📱</div>
                  <div class="text-xs font-medium">{project.title}</div>
                </div>
              </div>
            )}
            
            <!-- Corner decorations -->
            <div class="absolute top-3 right-3 w-6 h-6 border-t border-r border-white/10 z-20 group-hover:border-blue-400/30 transition-colors duration-500"></div>
            <div class="absolute bottom-3 left-3 w-6 h-6 border-b border-l border-white/10 z-20 group-hover:border-purple-400/30 transition-colors duration-500"></div>
          </div>
          
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2 text-white group-hover:text-gradient transition-all duration-300">
              {project.link ? (
                <a href={project.link} class="hover:opacity-90 transition-opacity">
                  {project.title}
                </a>
              ) : (
                project.title
              )}
            </h3>
            
            <p class="text-white/50 mb-5 text-sm leading-relaxed line-clamp-3">{project.description}</p>
            
            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.tags.map((tag) => (
                <span class={`px-2.5 py-1 rounded-lg text-[11px] font-semibold border ${tagColors[tag] || defaultTagColor}`}>{tag}</span>
              ))}
            </div>
            
            <!-- Links -->
            <div class="flex gap-3">
              {project.link && (
                <a 
                  href={project.link} 
                  class="flex-1 px-4 py-2.5 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl hover:from-blue-500 hover:to-purple-500 transition-all duration-300 shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 flex items-center justify-center text-sm font-semibold"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                  </svg>
                  Ver
                </a>
              )}
              
              {project.github && (
                <a 
                  href={project.github} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="px-4 py-2.5 border border-white/[0.08] rounded-xl hover:bg-white/[0.04] hover:border-white/[0.15] transition-all duration-300 text-white/60 hover:text-white flex items-center justify-center text-sm font-medium"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.167 6.839 9.489.5.092.682-.217.682-.48 0-.237-.01-1.017-.014-1.845-2.782.603-3.369-1.188-3.369-1.188-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.09-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.022A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.29 2.747-1.022 2.747-1.022.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.841-2.337 4.687-4.565 4.935.359.309.678.917.678 1.852 0 1.335-.012 2.415-.012 2.741 0 .267.18.577.688.48C19.137 20.164 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                  </svg>
                  GitHub
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>