---
interface Props {
  title?: string;
  description?: string[];
}

const { 
  title = "Sobre Mí",
  description = [
    "Soy un desarrollador web apasionado por crear experiencias digitales excepcionales.",
    "Con experiencia en tecnologías frontend y backend, me enfoco en construir aplicaciones web modernas, rápidas y accesibles.",
    "Me gusta aprender constantemente nuevas tecnologías y enfrentar desafíos que me permitan crecer profesionalmente."
  ]
} = Astro.props;

const highlights = [
  { icon: "🎨", label: "Diseño UI/UX", color: "blue" },
  { icon: "💻", label: "Desarrollo Web", color: "purple" },
  { icon: "🚀", label: "Innovación", color: "blue" },
  { icon: "⚡", label: "Performance", color: "purple" },
];
---

<section id="sobre-mi" class="relative py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#050510] via-[#070718] to-[#050510] z-0">
    <div class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section heading -->
    <div class="text-center mb-16 animate-on-scroll">
      <div class="inline-block mb-4">
        <span class="px-4 py-1.5 bg-white/[0.03] text-blue-400 rounded-full text-xs font-semibold tracking-widest uppercase border border-white/[0.06] backdrop-blur-sm">
          Conóceme
        </span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4 tracking-tight">{title}</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-purple-600 mx-auto rounded-full"></div>
    </div>
    
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row gap-12 items-center glass rounded-3xl p-8 md:p-10 animate-on-scroll">
        <div class="md:w-2/5 w-full">
          <div class="relative mx-auto max-w-xs">
            <!-- Decorative frame -->
            <div class="absolute -inset-3 bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-3xl blur-xl"></div>
            <div class="absolute -inset-px bg-gradient-to-br from-blue-500/30 to-purple-500/30 rounded-2xl"></div>
            
            <!-- Main image container -->
            <div class="relative z-10 bg-gradient-to-br from-[#0a0a1a] to-[#0f0f2a] p-1 rounded-2xl overflow-hidden">
              <div class="aspect-square rounded-xl overflow-hidden bg-gradient-to-br from-blue-900/40 to-purple-900/40 flex items-center justify-center">
                <span class="text-8xl">😊</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="md:w-3/5 w-full">
          <div class="space-y-4">
            {description.map((paragraph) => (
              <p class="text-base sm:text-lg leading-relaxed text-white/60">{paragraph}</p>
            ))}
          </div>
          
          <!-- Skills tags -->
          <div class="mt-8 flex flex-wrap gap-3 stagger-children">
            {highlights.map((tag) => (
              <span class={`inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium border transition-all duration-300 hover:scale-105 cursor-default
                ${tag.color === 'blue' 
                  ? 'bg-blue-500/[0.06] text-blue-300 border-blue-500/[0.12] hover:border-blue-500/30' 
                  : 'bg-purple-500/[0.06] text-purple-300 border-purple-500/[0.12] hover:border-purple-500/30'
                }`}>
                <span>{tag.icon}</span>
                {tag.label}
              </span>
            ))}
          </div>
          
          <div class="mt-8">
            <a href="#contacto" class="group relative inline-flex items-center justify-center px-6 py-3 overflow-hidden font-medium rounded-xl text-white text-sm">
              <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-blue-600 to-purple-600 group-hover:from-purple-600 group-hover:to-blue-600 transition-all duration-500"></span>
              <span class="relative flex items-center font-semibold tracking-wide">
                Contáctame
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>