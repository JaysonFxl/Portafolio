---
import Layout from '../../layouts/Layout.astro';

// Helper para crear rutas correctas
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;

const projectData = {
  title: "Yenito",
  description: "Aplicacion web moderna construida con Angular, TypeScript y Tailwind CSS, con servicios backend en Rust y .NET - Galeria de imagenes",
  tags: ["Angular", "TypeScript", "Tailwind CSS", "Rust", ".NET"]
};

const images = Array.from({ length: 4 }, (_, i) => ({
  id: i + 1,
  src: `${baseUrl}/projects/yenito/image-${i + 1}.png`,
  alt: `Yenito Screenshot ${i + 1}`,
  title: `Captura de pantalla ${i + 1}`
}));
---

<Layout title={`${projectData.title} - Galeria`}>
  <main class="min-h-screen bg-gradient-to-b from-black via-slate-950 to-black">
    <div class="relative pt-20 pb-12">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,transparent_calc(100%_-_1px),rgba(249,115,22,0.1)_calc(100%_-_1px))] bg-[size:5vw_5vw]"></div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="mb-8">
          <a
            href={`${baseUrl}/#proyectos`}
            class="inline-flex items-center px-4 py-2 bg-orange-900/30 text-orange-300 rounded-lg border border-orange-800/30 hover:bg-orange-800/30 transition-all duration-300 backdrop-blur-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            Volver a Proyectos
          </a>
        </div>

        <div class="text-center mb-12">
          <div class="inline-block mb-4">
            <span class="px-3 py-1 bg-orange-900/30 text-orange-400 rounded-full text-xs font-medium border border-orange-800/30 backdrop-blur-sm">
              GALERIA DEL PROYECTO
            </span>
          </div>

          <h1 class="text-5xl font-bold text-white mb-4">{projectData.title}</h1>
          <div class="w-32 h-1 bg-gradient-to-r from-orange-500 to-amber-500 mx-auto rounded-full mb-6"></div>
          <p class="text-xl text-orange-100/70 max-w-3xl mx-auto mb-8">{projectData.description}</p>

          <div class="bg-orange-900/20 border border-orange-800/30 rounded-lg p-4 max-w-3xl mx-auto mb-8 backdrop-blur-sm">
            <h3 class="text-lg font-semibold text-orange-300 mb-2">Caracteristicas principales:</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm text-orange-100/80">
              <div class="flex items-center">
                <span class="text-orange-400 mr-2">•</span>
                Frontend SPA con Angular
              </div>
              <div class="flex items-center">
                <span class="text-orange-400 mr-2">•</span>
                Tipado robusto con TypeScript
              </div>
              <div class="flex items-center">
                <span class="text-orange-400 mr-2">•</span>
                UI utilitaria con Tailwind CSS
              </div>
              <div class="flex items-center">
                <span class="text-orange-400 mr-2">•</span>
                Servicios de alto rendimiento en Rust
              </div>
              <div class="flex items-center">
                <span class="text-orange-400 mr-2">•</span>
                Integracion backend con .NET
              </div>
              <div class="flex items-center">
                <span class="text-orange-400 mr-2">•</span>
                Arquitectura full-stack moderna
              </div>
            </div>
          </div>

          <div class="flex flex-wrap justify-center gap-3 mb-8">
            {projectData.tags.map((tag) => (
              <span class="px-4 py-2 bg-orange-900/30 text-orange-300 rounded-full text-sm border border-orange-800/30 backdrop-blur-sm">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-6 pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {images.map((image, index) => (
          <div
            class="group relative aspect-[16/10] bg-gradient-to-br from-orange-900/20 to-amber-900/20 rounded-xl overflow-hidden border border-white/10 hover:border-orange-500/30 transition-all duration-300 cursor-pointer"
            data-image-index={index}
          >
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-contain opacity-90 group-hover:opacity-100 transition-all duration-300 group-hover:scale-105 bg-black/5"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-orange-900/40 to-amber-900/40 group-hover:from-orange-800/60 group-hover:to-amber-800/60 transition-all duration-300" style="display: none;">
              <div class="text-center text-white/50 group-hover:text-white/70">
                <div class="text-2xl mb-2">YN</div>
                <div class="text-xs">Imagen {image.id}</div>
              </div>
            </div>

            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-4 left-4 right-4">
                <h3 class="text-white font-medium text-sm">{image.title}</h3>
                <p class="text-orange-200/80 text-xs mt-1">Click para ver en tamano completo</p>
              </div>
            </div>

            <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="bg-orange-600/80 rounded-full p-2 backdrop-blur-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div id="imageModal" class="fixed inset-0 bg-black/95 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="relative max-w-6xl w-full max-h-[90vh]">
          <button id="closeModal" class="absolute -top-12 right-0 text-white hover:text-orange-400 transition-colors z-10 bg-orange-900/30 rounded-full p-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          <div id="modalContent" class="bg-gradient-to-br from-orange-900/20 to-amber-900/20 rounded-xl border border-white/10 overflow-hidden">
            <div class="text-center text-white p-8">
              <div class="text-4xl mb-4">YN</div>
              <h3 class="text-xl font-bold mb-2">Vista ampliada</h3>
              <p class="text-orange-100/70">Aqui se mostrara la imagen seleccionada</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const modal = document.getElementById('imageModal');
      const closeModal = document.getElementById('closeModal');
      const modalContent = document.getElementById('modalContent');
      const imageCards = document.querySelectorAll('[data-image-index]');
      let currentImageIndex = 0;

      const metaElement = document.querySelector('meta[name="astro-base-url"]');
      const baseUrl = metaElement ? metaElement.getAttribute('content') || '/Portafolio' : '/Portafolio';

      const images = Array.from({ length: 4 }, (_, i) => ({
        id: i + 1,
        src: `${baseUrl}/projects/yenito/image-${i + 1}.png`,
        alt: `Yenito Screenshot ${i + 1}`,
        title: `Captura de pantalla ${i + 1}`
      }));

      function showImageInModal(index: number) {
        const image = images[index];
        currentImageIndex = index;

        if (modalContent) {
          modalContent.innerHTML = `
            <div class="relative">
              <img
                src="${image.src}"
                alt="${image.alt}"
                class="w-full max-h-[75vh] object-contain bg-black/10"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="w-full h-96 flex items-center justify-center bg-gradient-to-br from-orange-900/40 to-amber-900/40" style="display: none;">
                <div class="text-center text-white">
                  <div class="text-4xl mb-4">YN</div>
                  <h3 class="text-xl font-bold mb-2">${image.title}</h3>
                  <p class="text-orange-100/70">Imagen no disponible</p>
                </div>
              </div>

              ${index > 0 ? `
                <button id="prevImage" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/60 hover:bg-black/80 text-white rounded-full p-3 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </button>
              ` : ''}

              ${index < images.length - 1 ? `
                <button id="nextImage" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/60 hover:bg-black/80 text-white rounded-full p-3 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                </button>
              ` : ''}
            </div>
            <div class="p-6 bg-gradient-to-r from-orange-900/30 to-amber-900/30">
              <h3 class="text-lg font-bold text-white mb-2">${image.title}</h3>
              <p class="text-orange-100/70 text-sm">Yenito - Imagen ${image.id} de 4</p>
              <div class="flex items-center justify-between mt-4">
                <div class="flex space-x-2">
                  <span class="px-2 py-1 bg-orange-600/30 text-orange-300 rounded text-xs">Screenshot</span>
                  <span class="px-2 py-1 bg-amber-600/30 text-amber-300 rounded text-xs">Angular App</span>
                </div>
                <p class="text-xs text-white/50"><- -> arrow keys or ESC to close</p>
              </div>
            </div>
          `;

          const prevBtn = document.getElementById('prevImage');
          const nextBtn = document.getElementById('nextImage');

          if (prevBtn) {
            prevBtn.addEventListener('click', () => showImageInModal(index - 1));
          }

          if (nextBtn) {
            nextBtn.addEventListener('click', () => showImageInModal(index + 1));
          }
        }
      }

      imageCards.forEach((card, index) => {
        card.addEventListener('click', () => {
          showImageInModal(index);
          modal?.classList.remove('hidden');
          modal?.classList.add('flex');
        });
      });

      closeModal?.addEventListener('click', () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      });

      modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      });

      document.addEventListener('keydown', (e) => {
        if (modal && !modal.classList.contains('hidden')) {
          if (e.key === 'Escape') {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
          } else if (e.key === 'ArrowLeft' && currentImageIndex > 0) {
            showImageInModal(currentImageIndex - 1);
          } else if (e.key === 'ArrowRight' && currentImageIndex < images.length - 1) {
            showImageInModal(currentImageIndex + 1);
          }
        }
      });
    });
  </script>
</Layout>
